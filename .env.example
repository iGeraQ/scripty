# ─────────────────────────────────────────────
#  Scripty – Job Runner  |  .env.example
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# App
APP_ENV=development          # development | staging | production
APP_NAME=scripty-job-runner

# Job configuration
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=5
JOB_TIMEOUT_SECONDS=30
JOB_CONCURRENCY=4

# Simulated worker endpoint (no real API key needed in dev)
WORKER_BASE_URL=http://localhost:8080
WORKER_API_KEY=your-api-key-here

# Logging
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=false
LOG_FILE_PATH=logs/scripty.log

# Notifications (simulated)
NOTIFY_ON_FAILURE=true
NOTIFY_ON_SUCCESS=false
NOTIFY_EMAIL=ops@example.com
